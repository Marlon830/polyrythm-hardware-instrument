  {
    "name": "808_bass",
    "modules": [
      {
        "type": "oscillator",
        "name": "osc_808",
        "params": {
          "waveform": "sine",
          "pitch" : -12
        }
      },
      {
        "type": "envelope",
        "name": "pitch_env",
        "params": {
          "attack": 0.0,
          "decay": 0.1,
          "sustain": 0.0,
          "release": 0.05
        }
      },  
      {
        "type" : "adsr",
        "name" : "amp_env",
        "params" : {
          "attack": 0.3,
          "decay": 0.2,
          "sustain": 0.2,
          "release": 1.1
        }
      },
      {
        "type": "instrument_audio_out",
        "name": "instrument_audio_out"
      }
    ],
    "connections": [
      {"from": "pitch_env:out", "to": "osc_808:FreqCV"},
      {"from": "osc_808:out", "to": "amp_env:in"},
      {"from": "amp_env:out", "to": "instrument_audio_out:in"}
    ]
  }